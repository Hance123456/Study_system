        <mxCell id="fetch" value="调用详情接口&#xa;获取完整测验数据" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#2E7D32;fontColor=#1B5E20;fontSize=13" vertex="1" parent="1">
