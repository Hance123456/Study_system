        <mxCell id="modal" value="打开 Modal 弹窗&#xa;(afterOpenChange=true)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3E5F5;strokeColor=#7B1FA2;fontColor=#7B1FA2;fontStyle=1;fontSize=13" vertex="1" parent="1">
