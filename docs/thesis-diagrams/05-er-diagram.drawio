  <diagram id="er-diagram" name="数据库 E-R 图">
    <mxGraphModel dx="1950" dy="1150" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1100" pageHeight="850" math="0" shadow="0">
      <root>
