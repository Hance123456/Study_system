        <mxCell id="a5" value="记录后" style="endArrow=classic;html=1;rounded=0;strokeColor=#2E7D32;fontSize=12" edge="1" parent="1" source="record" target="quiz"/>
        <mxCell id="a6" value="" style="endArrow=classic;html=1;rounded=0;strokeColor=#7B1FA2;fontSize=12" edge="1" parent="1" source="quiz" target="end"/>
