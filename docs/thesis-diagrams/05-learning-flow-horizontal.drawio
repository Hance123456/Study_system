        <mxCell id="quiz" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3E5F5;strokeColor=#7B1FA2;fontColor=#4A148C;fontSize=13.5" value="6. 可选进入测验&#xa;按卡片拉取题目&#xa;支持多种题型" vertex="1">
