        <mxCell id="record" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#2E7D32;fontColor=#1B5E20;fontSize=13.5" value="5. 记录学习行为&#xa;更新 user_progress&#xa;统计学习时长与掌握度" vertex="1">
          <mxGeometry height="80" width="200" x="890" y="120" as="geometry" />
