# 服务器配置
NODE_ENV=development
HOST=0.0.0.0
PORT=3000
CORS_ORIGIN=*

# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=study_system_db

# 上传目录配置（本地建议使用 backend/uploads；云托管可设为 /tmp/uploads 或挂载目录）
UPLOAD_BASE_DIR=./uploads

# JWT 配置
JWT_SECRET=your_jwt_secret_key

# 微信小程序配置
WECHAT_APP_ID=your_app_id
WECHAT_APP_SECRET=your_app_secret

# 腾讯云 COS（可选：四项都填则图片/音频/TTS/头像写入 COS，重启云托管不丢）
# 控制台创建存储桶后，开启「公有读私有写」或自定义域名；小程序需在后台配置 downloadFile 合法域名为 COS 域名
COS_SECRET_ID=
COS_SECRET_KEY=
COS_BUCKET=your-bucket-1250000000
COS_REGION=ap-shanghai
# 可选：CDN 或自定义域名，不填则用 https://{bucket}.cos.{region}.myqcloud.com
COS_PUBLIC_BASE_URL=
