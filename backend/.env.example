# 服务器配置
NODE_ENV=development
HOST=0.0.0.0
PORT=3000
CORS_ORIGIN=*

# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=study_system_db

# 上传目录配置（本地建议使用 backend/uploads；云托管可设为 /tmp/uploads 或挂载目录）
UPLOAD_BASE_DIR=./uploads

# JWT 配置
JWT_SECRET=your_jwt_secret_key

# 微信小程序配置
WECHAT_APP_ID=your_app_id
WECHAT_APP_SECRET=your_app_secret
